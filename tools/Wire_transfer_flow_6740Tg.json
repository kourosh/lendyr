          "description": "ID of authenticated customer."
        },
        "account_type": {
          "type": "string",
          "description": "Type of account where the money will come from — e.g. checking or savings."
        },
        "routing_number": {
          "type": "integer",
          "description": "Routing number of the bank where the customer wants to wire the money."
        },
        "account_number": {
          "type": "integer",
          "description": "Account number of the person or business where the customer wants to wire the money."
        },
        "name": {
          "type": "string",
          "default": "",
          "description": "Full name of the person or the business to whom the customer wants to send the money."
        }
      }
    },
