{
  "openapi": "3.1.0",
  "info": {
    "title": "Lendyr Bill Payment API",
    "version": "1.0.0",
    "description": "API for creating bill payments via check mailing service"
  },
  "servers": [
    {
      "url": "https://lendyr-db2-api.28d7yzowjq08.us-south.codeengine.appdomain.cloud",
      "description": "Lendyr Bank API Server"
    }
  ],
  "paths": {
    "/customers/by-id/{customer_id}/bill-payments": {
      "post": {
        "operationId": "create_bill_payment",
        "summary": "Create a bill payment via check",
        "description": "Creates a bill payment request. Lendyr will mail a physical check to the payee address.",
        "tags": ["Bill Payments"],
        "parameters": [
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier of the customer",
            "x-ibm-context-mapping": "customer_id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["payee_name", "payee_address", "amount", "account_type"],
                "properties": {
                  "payee_name": {"type": "string"},
                  "payee_address": {
                    "type": "object",
                    "required": ["street", "city", "state", "zip"],
                    "properties": {
                      "street": {"type": "string"},
                      "city": {"type": "string"},
                      "state": {"type": "string"},
                      "zip": {"type": "string"}
                    }
                  },
                  "amount": {"type": "number", "minimum": 0.01},
                  "account_type": {"type": "string", "enum": ["checking", "savings"]},
                  "invoice_number": {"type": "string"},
                  "memo": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bill payment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean"},
                    "payment_id": {"type": "string"},
                    "check_number": {"type": "string"},
                    "message": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "get_bill_payments",
        "summary": "Get bill payment history",
        "description": "Returns all bill payments for a customer with optional status filtering",
        "tags": ["Bill Payments"],
        "parameters": [
          {
            "name": "customer_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "The unique identifier of the customer",
            "x-ibm-context-mapping": "customer_id"
          }
        ],
        "responses": {
          "200": {
            "description": "List of bill payments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"type": "object"}
                }
              }
            }
          }
        }
      }
    }
  }
}
